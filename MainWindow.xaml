<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MyPdfViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MyPdfViewer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PDF Viewer"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="PDF Viewer"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--  IsSettingsVisible="False" removes the auto-generated second Settings item  -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>

                <NavigationViewItem
                    x:Name="NavItemAllPdfs"
                    Content="All PDFs"
                    IsSelected="True"
                    Tag="allpdfs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71D;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!--  Virtual Folders — sub-items loaded dynamically in code-behind  -->
                <NavigationViewItem
                    x:Name="NavItemFolders"
                    Content="Virtual Folders"
                    Tag="folders">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                    <!--  Child items injected by RefreshFolderNavItemsAsync()  -->
                </NavigationViewItem>

                <NavigationViewItem
                    x:Name="NavItemBookmarks"
                    Content="Bookmarks"
                    Tag="bookmarks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!--  Footer — single Settings item (no duplicate)  -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    x:Name="NavItemSettings"
                    Content="Settings"
                    Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>
