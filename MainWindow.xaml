<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MyPdfViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MyPdfViewer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MyPdfViewer"
    mc:Ignorable="d">

    <!--  Mica backdrop for authentic Windows 11 material  -->
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════════════════════════════════════════════════════════════
              TITLE BAR — custom WinUI 3 TitleBar control
              ═══════════════════════════════════════════════════════════════════ -->
        <TitleBar
            x:Name="AppTitleBar"
            Title="PDF Viewer"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--  ═══════════════════════════════════════════════════════════════════
              NAVIGATION VIEW — left-pane layout, three nav items per spec
              ═══════════════════════════════════════════════════════════════════ -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>

                <!--  All PDFs — FontIcon: AllApps &#xE71D;  -->
                <NavigationViewItem
                    x:Name="NavItemAllPdfs"
                    Content="All PDFs"
                    IsSelected="True"
                    Tag="allpdfs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71D;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!--  Virtual Folders — FontIcon: Folder &#xE8B7;  -->
                <NavigationViewItem
                    x:Name="NavItemFolders"
                    Content="Virtual Folders"
                    Tag="folders">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!--  Bookmarks — FontIcon: Bookmarks &#xE8A4;  -->
                <NavigationViewItem
                    x:Name="NavItemBookmarks"
                    Content="Bookmarks"
                    Tag="bookmarks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!--  NavigationView footer — Settings item is auto-generated  -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!--  Content frame — pages are pushed onto this frame  -->
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>
