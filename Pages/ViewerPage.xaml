<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MyPdfViewer.Pages.ViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MyPdfViewer.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <CommandBar x:Name="ViewerCommandBar" DefaultLabelPosition="Right" IsOpen="False">
            <AppBarButton
                x:Name="BtnOpenFile"
                Click="BtnOpenFile_Click"
                Icon="OpenFile"
                Label="Open PDF" />
            <AppBarButton
                x:Name="BtnAddToFolder"
                Click="BtnAddToFolder_Click"
                IsEnabled="False"
                Label="Add to Folder">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8B7;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                x:Name="BtnBookmark"
                Click="BtnBookmark_Click"
                IsEnabled="False"
                Label="Bookmark">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A4;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <WebView2 x:Name="PdfWebView" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Grid
            Grid.Row="1"
            x:Name="EmptyStatePlaceholder"
            Width="640"
            Height="460"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="12">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <TextBlock Text="Open a PDF to get started" />
                <Button Click="BtnOpenFile_Click" Content="Open PDF File" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
