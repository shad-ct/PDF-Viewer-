<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MyPdfViewer.Pages.AllPdfsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MyPdfViewer.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <FontIcon FontSize="28" Glyph="&#xE71D;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Text="All PDFs" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button x:Name="BtnAddPdf" Content="Open PDF" Click="BtnAddPdf_Click"
                    Style="{ThemeResource AccentButtonStyle}" VerticalAlignment="Center" Margin="16,0,0,0">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="O" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <!--  File list  -->
        <ListView
            x:Name="PdfListView"
            Grid.Row="1"
            SelectionMode="Single"
            ItemClick="PdfListView_ItemClick"
            IsItemClickEnabled="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xEA90;" FontSize="24"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding}" />
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
