<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MyPdfViewer.Pages.BookmarksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MyPdfViewer.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <FontIcon FontSize="28" Glyph="&#xE8A4;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Text="Bookmarks" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <ListView x:Name="BookmarkListView" Grid.Row="1"
                  SelectionMode="Single" IsItemClickEnabled="True"
                  ItemClick="BookmarkListView_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8A4;" FontSize="20"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                <Run Text="Page " />
                                <Run Text="{Binding PageNumber}" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{Binding FilePath}" TextTrimming="CharacterEllipsis"
                                   MaxWidth="260" />
                        <Button Grid.Column="3" Content="Remove" Tag="{Binding BookmarkId}"
                                Click="BtnRemoveBookmark_Click"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
